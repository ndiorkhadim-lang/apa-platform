# ─── APA Platform — environment ───────────────────────────────
# Copy to .env.local (dev) or set in Vercel Project Settings (prod).

# Database (production: Neon/Supabase pooled connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Better Auth (REQUIRED) — generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-32-bytes-base64"
BETTER_AUTH_URL="https://your-app.vercel.app"

# Public site URL (SEO: sitemap/robots) — same origin as the deployment
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# ─── Optional (activate features when ready) ──────────────────
# OAuth social sign-in (auto-enabled when both vars of a provider are set)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# Transactional email (Champion notifications) — Resend
# RESEND_API_KEY=""
# EMAIL_FROM="APA <no-reply@theapaafrica.org>"

# Cross-subdomain SSO for tools on certification.theapaafrica.org
# TOOLS_WORKSPACE_ORIGIN="https://certification.theapaafrica.org"
# AUTH_COOKIE_DOMAIN=".theapaafrica.org"
